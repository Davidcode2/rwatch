# Build stage
FROM rust:1.75-slim as builder

WORKDIR /app

# Copy workspace files
COPY Cargo.toml Cargo.lock ./
COPY common/Cargo.toml common/
COPY agent/Cargo.toml agent/

# Copy source code
COPY common/src common/src/
COPY agent/src agent/src/

# Build the agent in release mode
RUN cargo build --release -p rwatch-agent

# Runtime stage
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

# Copy the binary from builder
COPY --from=builder /app/target/release/rwatch-agent /usr/local/bin/rwatch-agent

# Expose the agent port
EXPOSE 3000

# Run the agent
ENTRYPOINT ["/usr/local/bin/rwatch-agent"]
